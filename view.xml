cat > webapp/view/Detail.view.xml << 'EOF'
<mvc:View
    controllerName="com.po.approval.controller.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    xmlns:form="sap.ui.layout.form">
    <Page title="Purchase Order Details" showNavButton="true" navButtonPress=".onNavBack">
        <content>
            <MessageStrip
                id="fraudAlert"
                visible="false"
                type="Error"
                showIcon="true"
                class="sapUiSmallMargin"/>
            <f:Card class="sapUiSmallMargin">
                <f:header>
                    <card:Header xmlns:card="sap.f.cards"
                        title="{poModel>/po_id}"
                        subtitle="{poModel>/vendor}"
                        statusText="{poModel>/status}"/>
                </f:header>
                <f:content>
                    <form:SimpleForm editable="false" layout="ResponsiveGridLayout">
                        <Label text="PO ID"/>
                        <Text text="{poModel>/po_id}"/>
                        <Label text="Vendor"/>
                        <Text text="{poModel>/vendor}"/>
                        <Label text="Category"/>
                        <Text text="{poModel>/category}"/>
                        <Label text="Amount"/>
                        <ObjectNumber number="{poModel>/amount}" unit="INR" emphasized="true"/>
                        <Label text="Description"/>
                        <Text text="{poModel>/description}"/>
                        <Label text="Requestor"/>
                        <Text text="{poModel>/requestor}"/>
                        <Label text="Status"/>
                        <ObjectStatus text="{poModel>/status}" state="{= ${poModel>/status} === 'Approved' ? 'Success' : ${poModel>/status} === 'Rejected' ? 'Error' : 'Warning'}"/>
                    </form:SimpleForm>
                </f:content>
            </f:Card>
        </content>
        <footer>
            <Toolbar>
                <ToolbarSpacer/>
                <Button text="Reject" type="Reject" icon="sap-icon://decline" press=".onReject"/>
                <Button text="Approve" type="Accept" icon="sap-icon://accept" press=".onApprove"/>
            </Toolbar>
        </footer>
    </Page>
</mvc:View>
EOF